# Coturn Server Environment Configuration

# External IP Configuration
# This is the public/LAN IP address that clients will use to reach the TURN server
# Can be auto-detected from HOST_IP environment variable during container startup
# or manually set for static deployments
EXTERNAL_IP=auto

# Relay IP Configuration
# Usually same as EXTERNAL_IP
# This is the IP address that will be allocated for media relay
RELAY_IP=auto

# TURN Credentials
# Username and password for TURN authentication
# MUST match the credentials configured in SFU server
TURN_USERNAME=sfuuser
TURN_PASSWORD=sfupass123

# Port Configuration (usually don't need to change)
# LISTENING_PORT=3478
# TLS_PORT=5349
# MIN_PORT=49152
# MAX_PORT=65535

# Realm
# The authentication realm
# REALM=sfu.local

# Production Deployment Example:
# For EC2 instance with public IP:
# EXTERNAL_IP=123.456.789.10
# RELAY_IP=123.456.789.10
# TURN_USERNAME=your_secure_username
# TURN_PASSWORD=your_secure_password
